__pycache__/
*.pyc
.env
logs/
# data_tables/ holds per-case CSVs (real or synthetic export). Keep the
# top-level README and the simulated/ + real/ subfolder READMEs tracked, but
# never commit actual CSV contents — they can carry sensitive PII.
data_tables/*/*/
!data_tables/simulated/README.md
!data_tables/real/README.md
.superpowers/
venv/
.venv/
.claude/
reports/